#!/bin/sh
# Judge-ready surface analyzer: Pico USB -> live DSP dashboard -> automatic decode.
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
cd "$ROOT"

if [ -x .venv/bin/python ]; then
    PY=.venv/bin/python
elif [ -x "$HOME/Desktop/naive-bayes-decoder/.venv/bin/python" ]; then
    # Development-Mac environment used during hardware integration.
    PY="$HOME/Desktop/naive-bayes-decoder/.venv/bin/python"
else
    echo "Preparing the analyzer Python environment (first run only)..."
    python3 -m venv .venv
    .venv/bin/pip install -r receiver/requirements.txt
    PY=.venv/bin/python
fi

printf '\n%s\n' '============================================================'
printf '%s\n'   ' ROCKO SURFACE ANALYZER — JUDGE DEMO'
printf '%s\n'   ' Connect the receiver Pico by USB before continuing.'
printf '%s\n'   ' Expected result: INJURED (0001), three agreeing frames.'
printf '%s\n\n' ' Close the dashboard or press Q / Esc to stop safely.'

# With no arguments the receiver auto-detects the single Pico USB serial port.
# Optional arguments remain available, e.g. --replay capture.csv.
exec "$PY" receiver/rocko_receiver.py "$@"
